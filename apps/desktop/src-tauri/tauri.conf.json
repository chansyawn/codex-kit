{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodexKit",
  "version": "0.0.0",
  "identifier": "com.codexkit.desktop",
  "build": {
    "beforeDevCommand": {
      "script": "vp dev ../runtime",
      "wait": false
    },
    "beforeBuildCommand": "node --experimental-strip-types ./scripts/prepare-sidecars.ts"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/codexkit-runtime"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
